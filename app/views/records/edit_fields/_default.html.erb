<% edit_fields_default_debug = true %>
<% puts( ">>> f.class.name=#{f.class.name}" ) if edit_fields_default_debug %>
<% if f.object.multiple? key %>
  <% puts( ">>> multi_value key=#{key}" ) if edit_fields_default_debug %>
  <% puts f.input key, as: :multi_value, input_html: { aria: { label: 'Enter aria label multi_value' }, class: 'form-control', data: { 'key' => key } }, required: f.object.required?(key) %>
  <%= f.input key, as: :multi_value, input_html: { aria: { label: 'Enter aria label multi_value' }, class: 'form-control', data: { 'key' => key } }, required: f.object.required?(key) %>
<% else %>
  <% puts( ">>> key=#{key}" ) if edit_fields_default_debug %>
  <% puts f.input key, input_html: { aria: { label: 'Enter aria label value' }, data: { 'key' => key } }, required: f.object.required?(key) %>
  <%= f.input key, input_html: { aria: { label: 'Enter aria label value' }, data: { 'key' => key } }, required: f.object.required?(key) %>
<% end %>
